{
  "name": "discord-presence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "pnpm -r --if-present clean",
    "dev": "pnpm -r --parallel --if-present dev",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "jiti": "^2.7.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
