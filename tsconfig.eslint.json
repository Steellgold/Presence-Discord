{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": ".",
    "types": ["chrome", "node", "vite/client"]
  },
  "include": [
    "eslint.config.ts",
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx",
    "apps/*/vite.config.ts",
    "apps/*/electron.vite.config.ts",
    "packages/*/src/**/*.ts"
  ]
}
