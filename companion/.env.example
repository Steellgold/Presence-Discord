# Optionnel — crée un fichier .env uniquement si tu veux surcharger les valeurs par défaut.
# Le fichier .env ne doit JAMAIS être commité.

# Surcharge l'application Discord utilisée pour la Rich Presence (optionnel).
# Discord Developer Portal → Applications → ton app → General Information
# DISCORD_CLIENT_ID=ton_client_id

# Surcharge la clé TMDB utilisée pour les titres d'épisodes et les covers (optionnel).
# Une clé est déjà intégrée — renseigne la tienne uniquement si tu veux utiliser ton quota.
# https://www.themoviedb.org/settings/api
# TMDB_API_KEY=your_tmdb_api_key
