{
  "name": "presence-discord-companion",
  "version": "1.0.0",
  "description": "Compagnon local : reçoit la présence depuis l'extension et la pousse à Discord (Rich Presence).",
  "main": "main.js",
  "scripts": {
    "start": "node dev-start.js",
    "build": "electron-builder --win portable"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.presence-discord.companion",
    "productName": "Presence Discord",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "**/*",
      "build/**",
      "!build/rcedit.exe",
      "!dist/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "portable": {
      "artifactName": "Presence-Discord.exe"
    }
  },
  "license": "MIT"
}
